# 服务监听端口，默认 81 生产环境
CODEVIEW_HTTP_PORT=81

# 服务监听端口
SERVER_PORT=3101
# 前端网页访问源地址，用于跨域配置
WEB_ORIGIN=http://localhost:3105
# 数据库文件存储路径
DATABASE_PATH=./data/asset-console.db
# 默认用户ID，本地开发时使用
DEFAULT_USER_ID=local-user
# 加密密钥，用于敏感数据加密，请替换为长随机字符串
ENCRYPTION_SECRET=replace-with-a-long-random-string
# 管理员登录用户名，默认 xinjie
ADMIN_USERNAME=xinjie
# 管理员登录密码，请替换为高强度密码
ADMIN_PASSWORD=replace-with-a-strong-admin-password
# GitHub访问令牌，用于获取仓库信息
GITHUB_TOKEN=
# 是否包含GitHub私有仓库，true为包含，false为不包含
GITHUB_INCLUDE_PRIVATE_REPOS=false
