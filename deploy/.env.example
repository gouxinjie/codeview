# CodeView Docker Compose 生产环境示例
# 文件建议放到 ECS：/var/www/codeview/shared/.env

# 宿主机映射配置
# 默认使用 81 端口，避免和宿主机常见的 80 端口服务冲突
CODEVIEW_HTTP_PORT=81
CODEVIEW_DATA_DIR=/var/www/codeview/shared/data

# 镜像地址
SERVER_IMAGE=crpi-5ue84w8rjgqxg0s0.cn-shanghai.personal.cr.aliyuncs.com/codeview/server:latest
WEB_IMAGE=crpi-5ue84w8rjgqxg0s0.cn-shanghai.personal.cr.aliyuncs.com/codeview/web:latest

# 服务端运行配置
SERVER_PORT=3101
# 这里必须与实际访问地址保持一致；当前默认端口为 81
WEB_ORIGIN=http://localhost:81
DATABASE_PATH=/app/data/asset-console.db
DEFAULT_USER_ID=local-user
ENCRYPTION_SECRET=replace-with-a-long-random-string
ADMIN_USERNAME=xinjie
ADMIN_PASSWORD=replace-with-a-strong-admin-password
GITHUB_TOKEN=
GITHUB_INCLUDE_PRIVATE_REPOS=false
