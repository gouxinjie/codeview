# CodeView Docker Compose 生产环境示例
# 文件建议放到 ECS：/var/www/codeview/shared/codeview.env

# 宿主机映射配置
CODEVIEW_HTTP_PORT=80
CODEVIEW_DATA_DIR=/var/www/codeview/shared/data

# 服务端运行配置
SERVER_PORT=3101
WEB_ORIGIN=http://localhost
DATABASE_PATH=/app/data/asset-console.db
DEFAULT_USER_ID=local-user
ENCRYPTION_SECRET=replace-with-a-long-random-string
